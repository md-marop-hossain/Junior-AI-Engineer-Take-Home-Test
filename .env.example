# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=stayease
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy / psycopg connection string. Mirror the values above.
DATABASE_URL=postgresql+psycopg://postgres:change-me@localhost:5432/stayease

# --- LLM (Groq / OpenRouter) -------------------------------------------------
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: use OpenRouter instead of Groq. Leave blank to default to Groq.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- App ---------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
